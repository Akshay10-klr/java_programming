package classwork;

import java.util.Scanner;
class Employee{
	int empid,empexperience;
	double empsalary;
	String name,email;
	
	Employee(int id,double salary,int exp,String n,String mail){
		empid=id;
		empsalary=salary;
		empexperience=exp;
		name=n;
		email=mail;
	}
	void display() {
		System.out.println("Employee id :"+empid);
		System.out.println("Employee name :"+name);
		System.out.println("Employee salary :"+empsalary);
		System.out.println("Employee experience :"+empexperience);
		System.out.println("Employee email :"+email);

		
	}
	void getBonus(){
		if(empexperience>5) {
			double bonus;
			bonus=empsalary*.3;
			empsalary=empsalary+bonus;
			System.out.println("incremented salary :"+empsalary);
		}
		else {
			System.out.println("not enough experience");
		}
	}
	void getIncrement() {
		if(empexperience>2) {
			double bonus;
			bonus=empsalary*.2;
			empsalary=empsalary+bonus;
			System.out.println("incremented salary :"+empsalary);
		}
		else {
			System.out.println("not enough experience");
		}
	}
	
}

