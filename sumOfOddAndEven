package looppack;

public class SumOddEven {

	public static void main(String[] args) {

		int sumOdd=0;
		int sumEven=0;
		for(int i=1;i<=20;i++) {
			if(i%2==0) {
				sumEven+=i;
			}else {
				sumOdd+=i;
			}
		}
		System.out.println("Sum of even number is :"+sumEven);
		System.out.println("Sum of odd number is :"+sumOdd);

	}

}
